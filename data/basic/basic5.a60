begin
  comment test #5 ;

  integer array arr [1:10 - 1 + 1];
  integer i;

  procedure init_array(b);
  begin
    integer j;
    for j := i_lwb(b, 1) step 1 until i_upb(b, 1) do
      b[j] := j * j;
  end;

  outstring(1, "test #5 array by names\n");
  init_array(arr);
  for i := 1 step 1 until 10 do
  begin
    outinteger(1, i);
    space(1);
    outinteger(1, arr[i]);
    newline(1);
  end;
end;
